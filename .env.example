# AI Accessibility Auditor - Environment Configuration (TEMPLATE)
# ==============================================================
# Copy this file to .env and fill in your actual values

# REQUIRED: Your OpenAI API key or compatible provider key
# Get your key from: https://platform.openai.com/api-keys
AI_API_KEY=sk-your-api-key-here

# OPTIONAL: Custom API endpoint (defaults to OpenAI)
# Use this if connecting to a different OpenAI-compatible provider
# Default: https://api.openai.com/v1/chat/completions
# AI_API_URL=https://api.openai.com/v1/chat/completions

# OPTIONAL: Model name to use
# Default: gpt-4.1-mini
# Supported: gpt-4, gpt-4-turbo, gpt-4.1-mini, etc.
# AI_MODEL=gpt-4.1-mini

# OPTIONAL: Enable or disable AI layer
# Set to "false" to disable AI-generated remediations (uses rule-based guidance only)
# Default: true
# AI_ENABLED=true
