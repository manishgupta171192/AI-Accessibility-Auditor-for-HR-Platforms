{
  "manifest_version": 3,
  "name": "AI Accessibility Auditor",
  "description": "Live WCAG auditing for HR and payroll dashboards.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["http://localhost:3000/*", "https://localhost:3000/*"],
  "action": {
    "default_title": "AI Accessibility Auditor",
    "default_popup": "popup.html"
  }
}